# CS-Scout production environment example.
# Copy to /etc/cs-scout/cs-scout.env and replace the placeholder secret.
# Generate a secret with: openssl rand -hex 32

CS_SCOUT_SECRET_KEY=REPLACE_WITH_A_RANDOM_64_CHARACTER_HEX_SECRET

# Keep mutable data outside the versioned release directory.
CS_SCOUT_DEMO_DIR=/var/lib/cs-scout/demos
CS_SCOUT_OUTPUT_DIR=/var/lib/cs-scout/output
CS_SCOUT_MAPS_DIR=/var/lib/cs-scout/maps

# Demo storage guardrails for the documented 60-GB VPS.
CS_SCOUT_DEMO_MAX_DOWNLOAD_MB=1024
CS_SCOUT_DEMO_CACHE_LIMIT_GB=16
CS_SCOUT_DEMO_CACHE_TARGET_GB=10
CS_SCOUT_DEMO_MIN_FREE_GB=8
CS_SCOUT_DEMO_TASK_DOWNLOAD_LIMIT_GB=12

# Optional defense against CDN DNS resolving to private addresses. Keep false
# when the deployment network legitimately accelerates the 5E CDN via RFC1918.
CS_SCOUT_DEMO_REQUIRE_PUBLIC_DNS=false

# Conservative defaults for an Ubuntu 24.04 VPS with 4 vCPU / 4 GB RAM.
CS_SCOUT_FAST_DOWNLOAD_WORKERS=4
CS_SCOUT_FAST_PARSE_WORKERS=1
CS_SCOUT_FAST_PARSE_MEMORY_PER_WORKER_MB=2048
CS_SCOUT_FAST_PARSE_MEMORY_RESERVE_MB=1024

PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
